{
  "name": "@clover.js/std",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "description": "Type-safe standard library for async streams, parsing, path/url handling, immutable data and Result/Option primitives.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsx --tsconfig ../../scripts/tsconfig.json ../../scripts/package-task.ts build",
    "prepublishOnly": "pnpm build",
    "lint": "pnpm exec tsx --tsconfig ../../scripts/tsconfig.json ../../scripts/package-task.ts lint",
    "lint:fix": "pnpm exec tsx --tsconfig ../../scripts/tsconfig.json ../../scripts/package-task.ts lint-fix",
    "unittest": "pnpm exec tsx --tsconfig ../../scripts/tsconfig.json ../../scripts/package-task.ts unittest",
    "unittest:coverage": "pnpm exec tsx --tsconfig ../../scripts/tsconfig.json ../../scripts/package-task.ts unittest-coverage",
    "typecheck": "pnpm exec tsx --tsconfig ../../scripts/tsconfig.json ../../scripts/package-task.ts typecheck"
  },
  "dependencies": {
    "@clover.js/protocol": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
