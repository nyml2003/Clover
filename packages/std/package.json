{
  "name": "@clover/std",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "description": "Type-safe standard library for async streams, parsing, path/url handling, immutable data and Result/Option primitives.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "python ../../scripts/package_tasks.py build",
    "prepublishOnly": "pnpm build",
    "lint": "python ../../scripts/package_tasks.py lint",
    "lint:fix": "python ../../scripts/package_tasks.py lint-fix",
    "unittest": "python ../../scripts/package_tasks.py unittest",
    "unittest:coverage": "python ../../scripts/package_tasks.py unittest-coverage",
    "typecheck": "python ../../scripts/package_tasks.py typecheck"
  },
  "dependencies": {
    "@clover/protocol": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}