{
  "name": "clover-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @clover/protocol run build && pnpm --filter @clover/std run build && pnpm --filter @clover/zod run build && pnpm --filter @clover/cli run build",
    "typecheck": "pnpm exec tsc -b tsconfig.json --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --configLoader native --coverage"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "esbuild": "0.28.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "zod": "4.3.6"
  }
}
