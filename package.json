{
  "name": "clover-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@clover.js/automation": "workspace:*",
    "@clover.js/cli": "workspace:*",
    "@clover.js/eslint-config": "workspace:*",
    "@clover.js/eslint-plugin": "workspace:*",
    "@clover.js/repo-command": "workspace:*",
    "@clover.js/protocol": "workspace:*",
    "@clover.js/std": "workspace:*",
    "@clover.js/tsconfig": "workspace:*",
    "@clover.js/http": "workspace:*",
    "@clover.js/zod": "workspace:*"
  },
  "scripts": {
    "build": "python ./scripts/workflow.py build",
    "build:legacy": "python ./scripts/workflow.py build",
    "lint": "pnpm repo:lint",
    "lint:legacy": "python ./scripts/workflow.py lint",
    "bench": "python ./scripts/workflow.py bench",
    "repo": "pnpm exec tsx ./packages/repo-command/src/main.ts",
    "repo:lint": "pnpm exec tsx ./packages/repo-command/src/main.ts lint",
    "repo:release-check": "pnpm exec tsx ./packages/repo-command/src/main.ts release-check",
    "test:system": "python ./scripts/workflow.py test-system",
    "release:check": "python ./scripts/workflow.py release-check",
    "typecheck": "python ./scripts/workflow.py typecheck",
    "test": "python ./scripts/workflow.py test",
    "test:coverage": "python ./scripts/workflow.py test-coverage"
  },
  "cloverBuildDefaults": {
    "outfile": "dist/index.js",
    "tsconfig": "tsconfig.json",
    "esbuild": {
      "bundle": true,
      "format": "esm",
      "platform": "node",
      "target": "es2024",
      "packages": "external",
      "minifySyntax": true,
      "minifyWhitespace": true,
      "legalComments": "none"
    },
    "dts": {
      "disableSymlinksFollowing": true
    }
  },
  "devDependencies": {
    "@eslint/core": "^0.17.0",
    "@eslint/js": "^9.39.1",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "0.28.0",
    "eslint": "^9.0.0",
    "jiti": "^2.6.1",
    "tinybench": "2.9.0",
    "tsx": "4.20.6",
    "typescript": "6.0.2",
    "undici-types": "7.19.2",
    "vitest": "4.1.4",
    "zod": "4.3.6"
  }
}
