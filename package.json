{
  "name": "clover-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@clover.js/automation": "workspace:*",
    "@clover.js/cli": "workspace:*",
    "@clover.js/eslint-config": "workspace:*",
    "@clover.js/eslint-plugin": "workspace:*",
    "@clover.js/repo-command": "workspace:*",
    "@clover.js/protocol": "workspace:*",
    "@clover.js/std": "workspace:*",
    "@clover.js/tsconfig": "workspace:*",
    "@clover.js/http": "workspace:*",
    "@clover.js/zod": "workspace:*"
  },
  "scripts": {
    "build": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts build",
    "lint": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts lint",
    "bench": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts bench",
    "test:system": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts test-system",
    "release:check": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts release-check",
    "typecheck": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts typecheck",
    "test": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts test",
    "test:coverage": "pnpm exec tsx --tsconfig ./scripts/tsconfig.json ./scripts/workflow.ts test-coverage"
  },
  "cloverBuildDefaults": {
    "outfile": "dist/index.js",
    "tsconfig": "tsconfig.json",
    "esbuild": {
      "bundle": true,
      "format": "esm",
      "platform": "node",
      "target": "es2024",
      "packages": "external",
      "minifySyntax": true,
      "minifyWhitespace": true,
      "legalComments": "none"
    },
    "dts": {
      "disableSymlinksFollowing": true
    }
  },
  "devDependencies": {
    "@eslint/core": "^0.17.0",
    "@eslint/js": "^9.39.1",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "0.28.0",
    "eslint": "^9.0.0",
    "jiti": "^2.6.1",
    "tinybench": "2.9.0",
    "tsx": "4.20.6",
    "typescript": "6.0.2",
    "undici-types": "7.19.2",
    "vitest": "4.1.4",
    "zod": "4.3.6"
  }
}
